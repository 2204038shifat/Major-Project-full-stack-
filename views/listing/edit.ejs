  <% layout("/layouts/boilerplate") %>

  <div class="row mb-3">
    <div class="col col-8 offset-2">

     <h3 class="mt-3 mb-3">Edit the listing</h3>

    <form method="POST" action="/listing/<%= listings._id %>?_method=PUT">

      <div class="mb-3 " >
        <label for="Title" class="form-label">Title :</label>
        <input type="text" class="form-control" name="listing[title]" 
    value="<%= listings.title %>" id="">

         
      </div>
    
      <div class="mb-3">
        <label for="description" class="form-label">Description :</label>
          <textarea name="listing[description]" class="form-control" type="text" id=""> <%= listings.description %> </textarea>
      </div>

      <div class="mb-3">
       
        <label for="image" class="form-label">Image :</label>
       <input name="listing[image]" class="form-control" id="" value="<%= listings.image %>">

      </div>

      <div class="row">


      <div class="col col-md-4 mb-3">

       <label for="Price" class="form-label">Price :</label>
    <input value="<%= listings.price %>" class="form-control" type="number" name="listing[price]" id="">

      </div>
     
    <div class="col col-md-7  mb-3">

     <label for="location" class="form-label">Locatioin :</label>
    <input type="text" name="listing[location]" class="form-control" value="<%= listings.location %>" id="">

    </div>
    </div>

  
    <div class="mb-3">
            <label for="country" class="form-label">Country :</label>
              <input class="form-control" value="<%= listings.country %>" type="text" 
    name="listing[country]" 
    id="">

    </div>
 <br>
    <button class="btn btn-dark">Edit</button>

  </form>



    </div>

  </div>

  
</body>
