<% layout("/layouts/boilerplate") %>

<body>

  <div class="container mt-4">

    <div class="row">
      <div class="col-md-8 mx-auto">

        <h2 class="mb-4 text-center">Show Individual List</h2>

        <!-- Card -->
        <div class="card shadow-sm mx-auto" style="max-width: 40rem;">
          <img
            src="<%= findListData.image.url %>"
            class="card-img-top"
            alt="image"
          />

          <div class="card-body">
            <h5 class="card-title"><%= findListData.title %></h5>

            <p class="card-text">
              <%= findListData.description %>
            </p>

            <p class="mb-1"><strong>Location:</strong> <%= findListData.location %></p>
            <p class="mb-1"><strong>Country:</strong> <%= findListData.country %></p>

            <h6 class="mt-2">
              &#2547; <%= findListData.price.toLocaleString('en-IN') %>
            </h6>
          </div>
        </div>

        <!-- Buttons -->
        <div class="d-flex justify-content-center gap-3 mt-4">
          
          <a 
            class="btn btn-outline-primary px-4"
            href="/listing/<%= findListData._id %>/edit"
          >
            Edit
          </a>

          <form
            method="POST"
            action="/listing/<%= findListData._id %>?_method=DELETE"
          >
            <button class="btn btn-outline-danger px-4">
              Delete
            </button>
          </form>

        </div>
        





     <div class="col-lg-8 offset-lg-2 mt-5">
    <h3 class="mb-4">Leave a Review</h3>

    <form method="post" action="/listing/<%= findListData._id %>/reviews">

        <!-- Rating -->
        <div class="mb-4">
            <label for="rating" class="form-label fw-semibold">
                Rating
            </label>

            <input
                type="range"
                class="form-range"
                min="1"
                max="5"
                step="1"
                id="rating"
                name="Review[rating]"
            >

            <div class="d-flex justify-content-between small text-muted">
                <span>1 ⭐</span>
                <span>2 ⭐</span>
                <span>3 ⭐</span>
                <span>4 ⭐</span>
                <span>5 ⭐</span>
            </div>
        </div>

        <!-- Comment -->
        <div class="mb-4">
            <label for="comment" class="form-label fw-semibold">
                Comment
            </label>

            <textarea
                class="form-control"
                id="comment"
                name="Review[comment]"
                rows="5"
                placeholder="Write your review..."
            ></textarea>
        </div>

        <!-- Button -->
        <button type="submit" class="btn btn-outline-danger px-4">
            Submit
        </button>

    </form>
</div>




      </div>
    </div>

  </div>

</body>